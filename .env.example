# ─── Local development (server/.env) ───────────────────────────────────────────

# Local Postgres (direct connection — set DIRECT_URL same as DATABASE_URL)
DATABASE_URL=postgresql://effortless:effortless@localhost:5432/effortless
DIRECT_URL=postgresql://effortless:effortless@localhost:5432/effortless

JWT_SECRET=change-me-to-a-long-random-string
CLIENT_URL=http://localhost:5173
PORT=4000

# ─── Vercel + Supabase (set in Vercel Project → Settings → Environment Variables)
#
# DATABASE_URL = Supabase → Settings → Database → Connection string → URI
#   Use "Transaction" pooler mode (port 6543) for serverless:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL = same page → "Session" or direct connection (port 5432) for migrations:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# JWT_SECRET = long random string (32+ chars)
# CLIENT_URL = https://your-app.vercel.app  (production; optional — VERCEL_URL is used as fallback)
# NODE_ENV = production

// Effortless data model. Migrate: npx prisma migrate deploy (from server/)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RewardTier {
  Bronze
  Silver
  Gold
  Diamond
  Platinum
  Royal
  King
  Emperor
  Planetary
  Stellar
  Galactic
}

enum SpinOutcome {
  Win
  LevelUp
  NoReward
  LevelDown
}

enum TaskSection {
  Must
  Should
  Could
}

enum TaskRecurrence {
  None
  Daily
  Weekly
  Monthly
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  googleId     String?       @unique
  createdAt    DateTime      @default(now())
  habits       Habit[]
  rewards      UserReward[]
  tokens       RewardToken[]
  spinLogs     SpinLog[]
  wheelConfigs   TierWheelConfig[]
  dailySettings  DailySettings?
  dailyBonusClaims DailyBonusClaim[]
  visions        Vision[]
  goals          Goal[]
}

model Habit {
  id               String      @id @default(cuid())
  userId           String
  name             String
  tier             RewardTier
  section          TaskSection    @default(Could)
  scheduledAt      DateTime?
  durationMinutes  Int?
  dueAt            DateTime?
  recurrence       TaskRecurrence @default(None)
  recurrenceConfig Json?
  persistAfterDone Boolean        @default(true)
  sortOrder        Int            @default(0)
  achievedAt       DateTime?
  archivedAt       DateTime?
  createdAt        DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserReward {
  id        String     @id @default(cuid())
  userId    String
  tier      RewardTier
  label     String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tier])
}

model RewardToken {
  id        String     @id @default(cuid())
  userId    String
  tier      RewardTier
  source    String
  spentAt   DateTime?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tier])
  @@index([userId, spentAt])
}

model DailySettings {
  userId               String      @id
  planningRewardTier   RewardTier?
  allMustsRewardTier   RewardTier?
  allDoDatesRewardTier RewardTier?
  updatedAt            DateTime    @updatedAt
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyBonusClaim {
  id        String     @id @default(cuid())
  userId    String
  dayKey    String
  bonusType String
  tier      RewardTier
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, bonusType])
  @@index([userId, dayKey])
}

model TierWheelConfig {
  id          String     @id @default(cuid())
  userId      String
  tier        RewardTier
  multiplier  Int        @default(1)
  sliceCounts Json       @default("{}")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tier])
  @@index([userId])
}

model Vision {
  id         String    @id @default(cuid())
  userId     String
  name       String
  sortOrder  Int       @default(0)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals      Goal[]

  @@index([userId])
}

model Goal {
  id          String    @id @default(cuid())
  visionId    String
  userId      String
  name        String
  sortOrder   Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  vision      Vision    @relation(fields: [visionId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([visionId])
  @@index([userId])
}

model SpinLog {
  id            String      @id @default(cuid())
  userId        String
  tokenTier     RewardTier
  outcome       SpinOutcome
  effectiveTier RewardTier
  rewardId      String?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, effectiveTier, createdAt])
}

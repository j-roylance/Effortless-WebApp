// Effortless data model. Migrate: npx prisma migrate deploy (from server/)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RewardTier {
  Bronze
  Silver
  Gold
  Diamond
  Platinum
  Royal
  King
  Emperor
  Planetary
  Stellar
  Galactic
}

enum SpinOutcome {
  Win
  LevelUp
  NoReward
  LevelDown
}

enum TaskSection {
  Must
  Should
  Could
}

enum TaskRecurrence {
  None
  Daily
  Weekly
  Monthly
}

enum TaskRewardKind {
  None
  Token
  Like
  Custom
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  googleId     String?       @unique
  createdAt    DateTime      @default(now())
  habits       Habit[]
  rewards      UserReward[]
  tokens       RewardToken[]
  spinLogs     SpinLog[]
  wheelConfigs   TierWheelConfig[]
  dailySettings  DailySettings?
  dailyBonusClaims DailyBonusClaim[]
  visions        Vision[]
  goals          Goal[]
  likeUsedCounts   LikeUsedCount[]
  tierLikeResets   TierLikeReset[]
  likeGrantLogs    LikeGrantLog[]
  likeCreditLedger LikeCreditLedger[]
}

model Habit {
  id               String         @id @default(cuid())
  userId           String
  name             String
  rewardKind       TaskRewardKind @default(Token)
  tier             RewardTier?
  rewardLikeId     String?
  customRewardLabel String?
  section          TaskSection    @default(Could)
  scheduledAt      DateTime?
  durationMinutes  Int?
  dueAt            DateTime?
  recurrence       TaskRecurrence @default(None)
  recurrenceConfig Json?
  scheduleOverrides Json?
  persistAfterDone Boolean        @default(true)
  sortOrder        Int            @default(0)
  achievedAt       DateTime?
  archivedAt       DateTime?
  createdAt        DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardLike       UserReward? @relation(fields: [rewardLikeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([rewardLikeId])
}

model UserReward {
  id             String          @id @default(cuid())
  userId         String
  tier           RewardTier
  label          String
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits         Habit[]
  likeUsedCounts   LikeUsedCount[]
  likeGrantLogs    LikeGrantLog[]
  likeCreditLedger LikeCreditLedger[]

  @@index([userId, tier])
}

model LikeUsedCount {
  id         String     @id @default(cuid())
  userId     String
  likeId     String
  bucketKey  String
  usedCount  Int        @default(0)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  like       UserReward @relation(fields: [likeId], references: [id], onDelete: Cascade)

  @@unique([userId, likeId, bucketKey])
  @@index([userId, bucketKey])
}

model TierLikeReset {
  id        String     @id @default(cuid())
  userId    String
  tier      RewardTier
  bucketKey String
  resetAt   DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tier, bucketKey])
}

model LikeGrantLog {
  id        String     @id @default(cuid())
  userId    String
  likeId    String
  tier      RewardTier
  source    String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  like      UserReward @relation(fields: [likeId], references: [id], onDelete: Cascade)

  @@index([userId, likeId, createdAt])
}

model LikeCreditLedger {
  id        String     @id @default(cuid())
  userId    String
  likeId    String
  bucketKey String
  delta     Int
  kind      String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  like      UserReward @relation(fields: [likeId], references: [id], onDelete: Cascade)

  @@index([userId, likeId, bucketKey])
}

model RewardToken {
  id        String     @id @default(cuid())
  userId    String
  tier      RewardTier
  source    String
  spentAt   DateTime?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tier])
  @@index([userId, spentAt])
}

model DailySettings {
  userId             String   @id
  planningReward     Json     @default("{\"kind\":\"none\"}")
  allMustsReward     Json     @default("{\"kind\":\"none\"}")
  allDoDatesReward   Json     @default("{\"kind\":\"none\"}")
  spinOutcomeWeights Json     @default("{\"win\":25,\"levelUp\":25,\"noReward\":25,\"levelDown\":25}")
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyBonusClaim {
  id          String      @id @default(cuid())
  userId      String
  dayKey      String
  bonusType   String
  tier        RewardTier?
  rewardLabel String?
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, bonusType])
  @@index([userId, dayKey])
}

model TierWheelConfig {
  id          String     @id @default(cuid())
  userId      String
  tier        RewardTier
  multiplier  Int        @default(1)
  sliceCounts Json       @default("{}")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tier])
  @@index([userId])
}

model Vision {
  id         String    @id @default(cuid())
  userId     String
  name       String
  sortOrder  Int       @default(0)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals      Goal[]

  @@index([userId])
}

model Goal {
  id           String    @id @default(cuid())
  visionId     String
  userId       String
  name         String
  sortOrder    Int       @default(0)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  parentGoalId String?
  vision       Vision    @relation(fields: [visionId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentGoal   Goal?     @relation("GoalSubgoals", fields: [parentGoalId], references: [id], onDelete: Cascade)
  subGoals     Goal[]    @relation("GoalSubgoals")

  @@index([visionId])
  @@index([userId])
  @@index([parentGoalId])
}

model SpinLog {
  id            String      @id @default(cuid())
  userId        String
  tokenTier     RewardTier
  outcome       SpinOutcome
  effectiveTier RewardTier
  rewardId      String?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, effectiveTier, createdAt])
}
